<Window
    x:Class="CodexAccountManager.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CodexAccountManager.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    Title="Codex 多账号管理器"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*,Auto" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <local:WrappingPanel Grid.Row="0" HorizontalSpacing="8" VerticalSpacing="8" Margin="16,10">
                <Button Click="CreateProfile_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add" />
                        <TextBlock Text="新建账号" />
                    </StackPanel>
                </Button>
                <Button Click="ImportAuthFile_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="OpenFile" />
                        <TextBlock Text="导入 auth 文件" />
                    </StackPanel>
                </Button>
                <Button Click="ImportCurrent_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Download" />
                        <TextBlock Text="导入当前 .codex" />
                    </StackPanel>
                </Button>
                <Button Click="ImportBackups_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Folder" />
                        <TextBlock Text="导入 auth-* 备份" />
                    </StackPanel>
                </Button>
                <Button Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
        </local:WrappingPanel>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" MinHeight="620">
            <Border Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*" Padding="18,12,12,12">
                    <TextBlock Text="账号" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListView
                        x:Name="ProfilesList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                        SelectionChanged="ProfilesList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,8" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding ActiveLabel}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <TextBlock Text="{Binding PlanType}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Status}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Row="2"
                                        Text="{Binding ProfileHome}"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" Padding="22,18,22,12">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.SelectedTitle, Mode=OneWay}" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.SelectedEmail, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                    <InfoBadge Grid.Column="1" Value="{x:Bind ViewModel.Profiles.Count, Mode=OneWay}" Margin="12,4,0,0" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="12" Margin="0,16,0,4">
                    <Border Padding="14,10" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.TotalProfilesText, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="账号总数" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="14,10" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.ReadyProfilesText, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="可启动" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="14,10" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.MissingAuthProfilesText, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="缺少凭据" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="14,10" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.ActiveProfilesText, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="当前账号" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <local:WrappingPanel Grid.Row="2" HorizontalSpacing="8" VerticalSpacing="8" Margin="0,12,0,12">
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="SetActive_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Contact" /><TextBlock Text="设为当前" /></StackPanel>
                        </Button>
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="SyncGlobal_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Sync" /><TextBlock Text="同步到全局" /></StackPanel>
                        </Button>
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="RefreshQuota_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Clock" /><TextBlock Text="刷新额度" /></StackPanel>
                        </Button>
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="RefreshMetadata_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Refresh" /><TextBlock Text="刷新凭据" /></StackPanel>
                        </Button>
                        <Button Click="OpenGlobalCodexHome_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Library" /><TextBlock Text="全局 .codex" /></StackPanel>
                        </Button>
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="Rename_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Edit" /><TextBlock Text="重命名" /></StackPanel>
                        </Button>
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="Backup_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Save" /><TextBlock Text="备份" /></StackPanel>
                        </Button>
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="Restore_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Repair" /><TextBlock Text="恢复" /></StackPanel>
                        </Button>
                        <Button IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" Click="Delete_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6"><SymbolIcon Symbol="Delete" /><TextBlock Text="删除" /></StackPanel>
                        </Button>
                </local:WrappingPanel>

                <Grid Grid.Row="3" ColumnDefinitions="1.2*,*" ColumnSpacing="18">
                    <ScrollViewer>
                        <StackPanel Spacing="14">
                            <Border Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="官方额度" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.QuotaStatusText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="1.1*,*,*,*,*" Padding="0,4,0,0">
                                        <TextBlock Text="额度" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="窗口" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="已用" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="3" Text="剩余" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="4" Text="重置时间" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                    <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.RateLimitRows, Mode=OneWay}" MaxHeight="180">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="1.1*,*,*,*,*" Padding="0,6">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Window}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Used}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Remaining}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding ResetsAt}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>

                            <Border Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="140,*" RowSpacing="10">
                                    <TextBlock Text="套餐" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedPlan, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="1" Text="状态" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SelectedStatus, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2" Text="最近检查" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SelectedLastCheck, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="3" Text="认证模式" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.SelectedAuthMode, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="4" Text="Account ID" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.SelectedAccountId, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                    <TextBlock Grid.Row="5" Text="会话数量" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.SelectedSessionCount, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="6" Text="最近会话" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{x:Bind ViewModel.SelectedLatestSession, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="7" Text="Profile Home" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{x:Bind ViewModel.SelectedProfileHome, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                    <TextBlock Grid.Row="8" Text="Auth Path" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{x:Bind ViewModel.SelectedAuthPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                    <TextBlock Grid.Row="9" Text="全局目录" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{x:Bind ViewModel.GlobalCodexHome, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                    <TextBlock Grid.Row="10" Text="启动命令" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBox
                                        Grid.Row="10"
                                        Grid.Column="1"
                                        Text="{x:Bind ViewModel.SelectedLaunchCommand, Mode=OneWay}"
                                        IsReadOnly="True"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <Border Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="备份" FontSize="18" FontWeight="SemiBold" />
                                    <ListView
                                        x:Name="BackupsList"
                                        Grid.Row="1"
                                        ItemsSource="{x:Bind ViewModel.Backups, Mode=OneWay}"
                                        MaxHeight="220"
                                        Margin="0,10,0,0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Padding="2,6">
                                                    <TextBlock Text="{Binding CreatedAt}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding BackupPath}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="操作日志" FontSize="18" FontWeight="SemiBold" />
                                <Button Grid.Column="1" Click="ClearLogs_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Clear" />
                                        <TextBlock Text="清空" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.OperationLogs, Mode=OneWay}" Margin="0,10,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="2,7">
                                            <TextBlock Text="{Binding Message}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Action}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" RowDefinitions="Auto,Auto">
            <TextBlock
                Padding="18,8"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap">
                <Run Text="版权声明：清远市启宇科技有限公司 | 官方网站：" />
                <Hyperlink NavigateUri="http://www.qyqiyu.com/">http://www.qyqiyu.com/</Hyperlink>
                <Run Text=" | 使用反馈：" />
                <Hyperlink NavigateUri="mailto:wxj124@qq.com">wxj124@qq.com</Hyperlink>
            </TextBlock>
            <InfoBar
                Grid.Row="1"
                IsOpen="True"
                Severity="Informational"
                Message="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
        </Grid>
    </Grid>
</Window>
